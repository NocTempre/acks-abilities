{
  "id": "acks-abilities",
  "title": "ACKS II — Abilities",
  "description": "Extended effect model and sheet for ACKS proficiencies, class powers, skills, and monster abilities.",
  "version": "0.8.1",
  "authors": [
    {
      "name": "NocTempre"
    }
  ],
  "license": "LICENSE",
  "compatibility": {
