    "verified": "14.364"
  },
  "relationships": {
    "systems": [
      {
        "id": "acks",
        "type": "system",
        "compatibility": {
          "minimum": "14"
        }
      }
    ],
    "requires": [
      {
        "id": "acks-lib",
        "type": "module",
        "compatibility": {
          "minimum": "0.6.0"
        }
      },
      {
        "id": "lib-wrapper",
        "type": "module",
        "reason": "Wraps AcksItem#rollFormula and #getTags so every route into an ability's roll — character sheet, chat card, item.use(), macros — reaches all of its rolls, not just the first one core can store.",
        "compatibility": {
          "minimum": "1.12.0"
        }
      }
    ]
  },
